{
  "name": "@jgalego/teamapi-rest-api",
  "version": "0.1.2",
  "description": "Read-only REST API over a resolved Team API org graph",
  "license": "MIT",
  "homepage": "https://github.com/JGalego/TeamAPI#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/JGalego/TeamAPI.git",
    "directory": "packages/rest-api"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && mkdir -p dist/dashboard && cp src/dashboard/index.html dist/dashboard/index.html",
    "clean": "rm -rf dist *.tsbuildinfo",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@jgalego/teamapi-core": "workspace:*",
    "@jgalego/teamapi-schema": "workspace:*",
    "fastify": "^5.1.0",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
