exports[`crewai generator — examples/acme-org > serializes the whole-org manifest to YAML 1`] = `
"crews:
  enabling-devex:
    name: Enabling DevEx
    config: enabling-devex/
    process: sequential
  platform-payments:
    name: Platform Payments
    config: platform-payments/
    process: hierarchical
    managerAgent: head_of_engineering
  stream-checkout:
    name: Stream Checkout
    config: stream-checkout/
    process: sequential
  stream-onboarding:
    name: Stream Onboarding
    config: stream-onboarding/
    process: sequential
relationships:
  - from: stream-checkout
    to: platform-payments
    kind: platform
    label: platform
  - from: stream-checkout
    to: platform-payments
    kind: interaction
    label: 'interaction (x-as-a-service): Consume payment processing and ledger services to reduce cognitive load'
  - from: stream-checkout
    to: stream-onboarding
    kind: interaction
    label: 'interaction (collaboration): Jointly define the applicant-to-customer handoff contract'
  - from: stream-checkout
    to: stream-onboarding
    kind: dependency
    label: 'dependency (Slowing): Checkout waits on the new applicant activation event schema before it can drop legacy polling'
  - from: stream-onboarding
    to: enabling-devex
    kind: interaction
    label: 'interaction (facilitating): Improve end-to-end test automation for the sign-up flow'
  - from: stream-onboarding
    to: platform-payments
    kind: dependency
    label: 'dependency (OK): Onboarding relies on the payments platform''s KYC verification integration'
"
`;
