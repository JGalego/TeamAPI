{
  "name": "team-topologies-toolchain",
  "private": true,
  "version": "0.1.0",
  "description": "Team Topologies + DDD Team API as Code toolchain: schema, organigrams, REST API, MCP server",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "teamapi": "node packages/cli/dist/main.js",
    "example:validate": "pnpm teamapi validate 'examples/acme-org/**/teamapi.yml'",
    "example:render": "pnpm teamapi render 'examples/acme-org/**/teamapi.yml' --scope topology",
    "example:serve-api": "pnpm teamapi serve-api 'examples/acme-org/**/teamapi.yml' --port 3000",
    "example:serve-mcp": "pnpm teamapi serve-mcp 'examples/acme-org/**/teamapi.yml'"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "@types/node": "^20.14.0",
    "vitest": "^2.1.4"
  },
  "packageManager": "pnpm@10.32.1"
}
